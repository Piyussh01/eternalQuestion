{
  "explorer": {
    "name": "explorer",
    "description": "Gemma 4 E4B — fast perspective and question generation",
    "base_url": "http://localhost:8001/v1",
    "model_id": "google/gemma-4-E4B-it",
    "vllm_args": {
      "model": "google/gemma-4-E4B-it",
      "port": 8001,
      "dtype": "auto",
      "max-model-len": 4096,
      "gpu-memory-utilization": 0.13,
      "max-num-seqs": 1,
      "enable-prefix-caching": false,
      "quantization": "fp8",
      "kv-cache-dtype": "fp8",
      "trust-remote-code": true
    },
    "generation": {
      "temperature": 0.9,
      "top_p": 0.95,
      "max_tokens": 512
    }
  },
  "reasoner": {
    "name": "reasoner",
    "description": "Gemma 4 26B MoE — answer synthesis, debate, and judging",
    "base_url": "http://localhost:8002/v1",
    "model_id": "google/gemma-4-26b-a4b-it",
    "vllm_args": {
      "model": "google/gemma-4-26b-a4b-it",
      "port": 8002,
      "dtype": "auto",
      "max-model-len": 8192,
      "gpu-memory-utilization": 0.55,
      "max-num-seqs": 1,
      "enable-prefix-caching": true,
      "quantization": "fp8",
      "kv-cache-dtype": "fp8",
      "trust-remote-code": true
    },
    "generation": {
      "temperature": 0.6,
      "top_p": 0.9,
      "max_tokens": 1024
    }
  },
  "memory_budget": {
    "total_unified_memory_gb": 128,
    "explorer_weights_gb": 8,
    "reasoner_weights_gb": 26,
    "vllm_overhead_gb": 10,
    "kv_cache_reserved_gb": 3,
    "system_reserved_gb": 8,
    "headroom_gb": 68,
    "minimum_available_gb_before_reasoner": 75,
    "notes": "Explorer uses Gemma 4 E4B for perspective/question generation and is capped at 4k context, one sequence, and a small FP8 KV budget. Reasoner uses Gemma 4 26B MoE with FP8, 8k context, and one sequence for answer synthesis, critique, and judging. This live pair is intended to fit where E4B plus 31B was too tight."
  }
}
